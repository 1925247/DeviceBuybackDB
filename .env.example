# ====================================================
# Device Buyback Platform - Environment Configuration
# Copy this file to .env and update with your values
# ====================================================

# ====================================================
# DATABASE CONFIGURATION
# ====================================================
DATABASE_URL=postgresql://username:password@localhost:5432/buyback_platform
PGHOST=localhost
PGPORT=5432
PGDATABASE=buyback_platform
PGUSER=your_username
PGPASSWORD=your_password

# ====================================================
# APPLICATION SETTINGS
# ====================================================
NODE_ENV=development
PORT=5000

# Session secret for authentication (generate a secure random string)
SESSION_SECRET=your-super-secure-session-secret-change-this

# ====================================================
# REDIS CONFIGURATION (Optional)
# ====================================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ====================================================
# EXTERNAL API SERVICES
# ====================================================

# Twilio for SMS notifications (optional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# SendGrid for email notifications (optional)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Stripe for payment processing (optional)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ====================================================
# INDIAN LOCALIZATION SERVICES
# ====================================================

# Indian Postal Service API (free, no key required)
# Used for PIN code validation and auto-fill
INDIAN_POSTAL_API_URL=https://api.postalpincode.in/pincode

# Alternative PIN code service (if needed)
ZIPPOPOTAM_API_URL=http://api.zippopotam.us/in

# ====================================================
# FILE UPLOAD CONFIGURATION
# ====================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# ====================================================
# LOGGING CONFIGURATION
# ====================================================
LOG_LEVEL=info
LOG_FORMAT=combined

# ====================================================
# SECURITY SETTINGS
# ====================================================

# CORS settings (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ====================================================
# DEPLOYMENT CONFIGURATION
# ====================================================

# Domain configuration for production
DOMAIN=yourdomain.com
PROTOCOL=https

# SSL Certificate paths (for production)
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# ====================================================
# MONITORING & ANALYTICS
# ====================================================

# Sentry for error tracking (optional)
SENTRY_DSN=your_sentry_dsn

# Google Analytics (optional)
GA_TRACKING_ID=GA-XXXXXXXX-X

# ====================================================
# DEVELOPMENT ONLY
# ====================================================

# Debug mode (development only)
DEBUG=true

# Enable detailed SQL logging (development only)
DB_LOGGING=true

# Mock external services (development only)
MOCK_SERVICES=false

# ====================================================
# FEATURE FLAGS
# ====================================================

# Enable/disable features
ENABLE_QUESTION_TARGETING=true
ENABLE_PIN_CODE_AUTOFILL=true
ENABLE_PARTNER_DASHBOARD=true
ENABLE_ADVANCED_PRICING=false
ENABLE_ML_PRICING=false

# ====================================================
# BACKUP CONFIGURATION
# ====================================================

# Database backup settings
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *
BACKUP_STORAGE_PATH=./backups

# ====================================================
# CACHE CONFIGURATION
# ====================================================

# Cache TTL settings (in seconds)
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=1800
CACHE_TTL_LONG=3600

# ====================================================
# NOTIFICATION SETTINGS
# ====================================================

# Admin notification email
ADMIN_EMAIL=admin@yourdomain.com

# System notification settings
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_PUSH_NOTIFICATIONS=false